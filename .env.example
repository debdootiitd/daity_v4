# Copy to .env and fill in. .env is gitignored.

# Path to a Google Cloud service account JSON key with BigQuery access
# to atomic-vault-476315-m3.daity_v3.
#
# RECOMMENDED: keep the SA key OUTSIDE this repo tree to minimize copy/leak
# surface (IDE syncs, agent sessions, Spotlight, Time Machine all touch the
# project dir). Example:
#   GOOGLE_APPLICATION_CREDENTIALS=$HOME/.config/gcloud/daity-sa.json
#
# An in-repo path (e.g. ./.sa-key.json) is gitignored but increases blast
# radius if any tool exfiltrates the working directory.
GOOGLE_APPLICATION_CREDENTIALS=$HOME/.config/gcloud/daity-sa.json

# BigQuery target
DAITY_BQ_PROJECT=atomic-vault-476315-m3
DAITY_BQ_DATASET=daity_v3
# DAITY_BQ_LOCATION is intentionally unset by default — auto-detected from the
# dataset by BQClient. Override only if you need to force a specific region.
# DAITY_BQ_LOCATION=asia-south1

# Local cache root for Parquet (Phase 1+)
DAITY_CACHE_ROOT=./data/parquet

# W&B (optional for Phase 0)
# WANDB_PROJECT=daity_v3
# WANDB_ENTITY=

# --- Groww historical-data API (Phase 1 ingest) ---
# Used by daity.scripts.refresh_ohlcv. The key may be either an API key
# (paired with secret to mint an access token) or a pre-issued access token
# (JWT starting with `eyJ`); the loader auto-detects which.
#
# Best practice: keep these in a SEPARATE file (e.g. .grow_cred.env, also
# gitignored) and let the loader auto-merge it. That keeps broker creds out of
# the BQ/cloud .env so you can rotate them independently.
# GROWW_API_KEY=
# GROWW_API_SECRET=
# Optional, only if Groww account requires TOTP at access-token mint time:
# GROWW_TOTP_SECRET=
