# --- Secrets (must be first; never commit these) ---
sa-key.json
.sa-key.json
*sa-key*.json
*service-account*.json
*credentials*.json
*-key.json
.env
.env.*
!.env.example
# Catch any *.env file (e.g. .grow_cred.env) and any *cred* file globally —
# defensive nets for future secret-shaped files that don't match the patterns above.
*.env
!.env.example
*cred*.env
*_cred*
*.token

