# --- Secrets (must be first; never commit these) ---
sa-key.json
.sa-key.json
*sa-key*.json
*service-account*.json
*credentials*.json
*-key.json
.env
.env.*
!.env.example
# Catch any *.env file (e.g. .grow_cred.env) and any *cred* file globally —
# defensive nets for future secret-shaped files that don't match the patterns above.
*.env
!.env.example
*cred*.env
*_cred*
*.token

# --- Data caches and artifacts ---
# IMPORTANT: leading slash anchors these to the repo root. Without it,
# `data/` would match `daity/data/` (the source package!) and silently
# exclude the entire Phase-1 data layer from git. Caught in Phase 2.4 PR.
/data/
/cache/
/parquet/
*.parquet
*.duckdb
*.duckdb.wal
/checkpoints/
/runs/
/wandb/
/mlruns/
reports/*.html
reports/*.json
reports/*.pt
reports/**/*.pt
!reports/.gitkeep

# Local agent / IDE state. Whitelist memory/ (durable cross-session notes
# for Claude agents); ignore transient runtime files like the schedule lock.
.claude/*
!.claude/memory/
!.claude/memory/**

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual envs
.venv/
.venv-*/
venv/
env/
ENV/

# Audit run artifacts
audit_run.log

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.hypothesis/

# Notebooks
.ipynb_checkpoints/
*.ipynb_meta

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Logs
*.log
logs/
